{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "History": {
      "title": "History",
      "description": "A history of queries made by the user",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user who made the query"
        },
        "query": {
          "type": "string",
          "description": "The query made by the user"
        },
        "response": {
          "type": "string",
          "description": "The response generated by the AI"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the query was made"
        }
      },
      "required": ["uid", "query", "response", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "history/{historyId}": {
      "schema": {
        "$ref": "#/entities/History"
      },
      "description": "Stores user queries and AI responses"
    }
  }
}
